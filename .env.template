# Copy this file to .env and fill in your Twilio details to enable real SMS alerts

# Server Port
PORT=3000

# Twilio Credentials (Optional - if missing, SMS will just print to console)
# Find these at https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Default Fallback Guardian Phone (Optional, used if victim app doesn't provide one)
# Format: +1234567890
GUARDIAN_PHONE=
